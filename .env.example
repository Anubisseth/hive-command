# =============================================
# HIVE COMMAND — Environment Variables
# Copy to .env and fill in your values
# =============================================

# ─── Airtable Backend ────────────────────────
# Get yours at: https://airtable.com/create/tokens
# Scopes needed: data.records:read, data.records:write
VITE_AIRTABLE_API_KEY=pat_your_token_here
VITE_AIRTABLE_BASE_ID=app_your_base_id_here

# Airtable Table IDs (find in Airtable URL or API docs)
VITE_AT_TBL_AGENTS=tbl_your_agents_table
VITE_AT_TBL_DIRECTIVES=tbl_your_directives_table
VITE_AT_TBL_TASKS=tbl_your_tasks_table
VITE_AT_TBL_OUTPUTS=tbl_your_outputs_table
VITE_AT_TBL_ACTIVITY=tbl_your_activity_table

# ─── Ollama LLM (Local AI) ──────────────────
# Install: https://ollama.com/download
# Pull a model: ollama pull llama3.2
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3.2

# ─── OpenAI API (Optional) ──────────────────
# For cloud LLM fallback when Ollama is unavailable
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini

# ─── Anthropic Claude API (Optional) ────────
# For advanced agent orchestration
VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── n8n Workflow Engine (Phase 3) ──────────
VITE_N8N_URL=
VITE_N8N_API_KEY=

# ─── Feature Flags ──────────────────────────
VITE_ENABLE_AI_ASSISTANT=true
VITE_ENABLE_3D_OFFICE=true
VITE_ENABLE_REALTIME=false
